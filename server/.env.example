# Server environment variables
# Copy to .env and fill values. Do not commit real keys.

# Server port (optional)
PORT=3000
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
HEALTH_RATE_LIMIT_WINDOW_MS=60000
HEALTH_RATE_LIMIT_MAX=120

# OpenWeather API
OPENWEATHER_API_KEY=
# Provide either OPENWEATHER_CITY or both OPENWEATHER_LAT and OPENWEATHER_LON
OPENWEATHER_CITY=Tagum City,PH
OPENWEATHER_LAT=7.4482
OPENWEATHER_LON=125.8094
WEATHER_CACHE_TTL_MS=3600000
OPENWEATHER_TIMEOUT_MS=8000
OPENWEATHER_CIRCUIT_ERROR_THRESHOLD=50
OPENWEATHER_CIRCUIT_RESET_MS=30000

# Supabase persistence (server-only; never expose these as VITE_* variables)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
WEATHER_LOCATION_ID=tagum-city-ph
SUPABASE_OBSERVATIONS_TABLE=daily_weather_observations
SUPABASE_HOURLY_OBSERVATIONS_TABLE=weather_observations
SUPABASE_FORECASTS_TABLE=daily_weather_forecasts
SUPABASE_CLIMATOLOGY_VIEW=hourly_climatology_90d
CLIMATOLOGY_CACHE_TTL_MS=900000
BACKFILL_START_DATE=2026-04-12
BACKFILL_END_DATE=
